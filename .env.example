# Kalshi API
KALSHI_API_KEY_ID=your-api-key-id
KALSHI_KEY_PATH=./secrets/kalshi_private.pem

# Weather APIs
VISUAL_CROSSING_API_KEY=your-vc-key
PIRATE_WEATHER_API_KEY=your-pw-key
OPENWEATHER_API_KEY=your-ow-key
NWS_USER_AGENT=(kalshi-weather-bot, your-email@example.com)

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=kalshi_weather
DB_USER=kalshi
DB_PASSWORD=change-me-in-production

# SendGrid (Sprint 3)
SENDGRID_API_KEY=your-sendgrid-key

# JWT (Sprint 4)
JWT_SECRET=generate-with-openssl-rand-hex-32

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
